# Copy this file to .env and fill in real values before running
# `docker compose up` in anything beyond local experimentation.

# Used to sign session tokens. Generate a real one with, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-value

# Postgres password (also used to build the api's DATABASE_URL automatically)
POSTGRES_PASSWORD=change-me-too
