{
  "name": "@schedule-app/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/jwt": "^10.2.0",
    "@schedule-app/crypto": "*",
    "@schedule-app/shared": "*",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
